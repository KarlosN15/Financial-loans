# URL de conexión a la base de datos (PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/santana_db"

# Secreto para tokens JWT (usar algo largo y complejo)
JWT_SECRET="reemplazar_con_secreto_seguro_en_produccion"

# Tiempo de expiración del token (v=24h, 7d, 1h)
JWT_EXPIRES_IN="1h"

# Puerto en el que corre el backend (opcional)
PORT=3000

# Configuración de CORS si es necesario (opcional)
CORS_ORIGIN="http://localhost:5173"
